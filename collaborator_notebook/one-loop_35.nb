     RowBox[{"{", 
      RowBox[{"1024", ",", "256"}], "}"}]}]}], "]"}], 
  ";"}], "\[IndentingNewLine]", 
 RowBox[{
  RowBox[{"ampsfse", "[", "0", "]"}], "=", 
  RowBox[{
   RowBox[{
    RowBox[{
     RowBox[{"FCFAConvert", "[", 
      RowBox[{
       RowBox[{"CreateFeynAmp", "[", "diagsfse", 
        RowBox[{"(*", 
         RowBox[{",", 
          RowBox[{"GaugeRules", "\[Rule]", 
           RowBox[{"{", "}"}]}]}], "*)"}], "]"}], ",", 
       RowBox[{"IncomingMomenta", "\[Rule]", 
        RowBox[{"{", "p", "}"}]}], ",", 
       RowBox[{"OutgoingMomenta", "\[Rule]", 
        RowBox[{"{", "p", "}"}]}], ",", 
       RowBox[{"UndoChiralSplittings", "\[Rule]", "True"}], ",", 
       "\[IndentingNewLine]", 
       RowBox[{"ChangeDimension", "\[Rule]", "D"}], ",", 
       RowBox[{"List", "\[Rule]", "False"}], ",", 
       RowBox[{"LoopMomenta", "\[Rule]", 
        RowBox[{"{", "l", "}"}]}], ",", 
       RowBox[{"SMP", "\[Rule]", "True"}], ",", 
       RowBox[{"Contract", "\[Rule]", "False"}], ",", 
       RowBox[{"DropSumOver", "\[Rule]", "True"}], ",", 
       RowBox[{"FinalSubstitutions", "\[Rule]", 
        RowBox[{"{", 
         RowBox[{
          RowBox[{"MQU", "[", "__", "]"}], "\[Rule]", "0"}], "}"}]}]}], "]"}],
      "/.", "\[IndentingNewLine]", 
     RowBox[{"{", 
      RowBox[{
       RowBox[{"IndexDelta", "[", 
        RowBox[{"a_", ",", "b_"}], "]"}], "\[Rule]", "1"}], "}"}]}], "//", 
    RowBox[{
     RowBox[{"ReplaceAll", "[", 
      RowBox[{
       RowBox[{"ReplaceAll", "[", 
        RowBox[{"#", ",", 
         RowBox[{
          RowBox[{
           RowBox[{"Spinor", "[", 
            RowBox[{
             RowBox[{"Momentum", "[", "___", "]"}], ",", "___"}], "]"}], ".", 
           "a_"}], "\[RuleDelayed]", "a"}]}], "]"}], ",", 
       RowBox[{
        RowBox[{"a_", " ", ".", 
         RowBox[{"Spinor", "[", 
          RowBox[{
           RowBox[{"Momentum", "[", "___", "]"}], ",", "___"}], "]"}]}], 
        "\[RuleDelayed]", "a"}]}], "]"}], "&"}]}], "//", 
   "Contract"}]}], "\[IndentingNewLine]", 
 RowBox[{
  RowBox[{"ampsfse", "[", "1", "]"}], "=", 
  RowBox[{"TID", "[", 
   RowBox[{
    RowBox[{"FCE", "[", 
     RowBox[{"SUNSimplify", "[", 
      RowBox[{"ampsfse", "[", "0", "]"}], "]"}], "]"}], ",", "l", ",", 
    RowBox[{"UsePaVeBasis", "\[Rule]", "True"}], ",", 
    RowBox[{"ToPaVe", "\[Rule]", "True"}]}], "]"}]}], "\n", 
 RowBox[{
  RowBox[{"ampsfse", "[", "2", "]"}], "=", 
  RowBox[{
   RowBox[{
    RowBox[{
     RowBox[{
      RowBox[{"(", 
       RowBox[{"FCReplaceD", "[", 
        RowBox[{
         RowBox[{
          RowBox[{"ampsfse", "[", "1", "]"}], "//", 
          "FeynAmpDenominatorExplicit"}], ",", 
         RowBox[{"D", "\[Rule]", 
          RowBox[{"4", "-", 
           RowBox[{"2", "Epsilon"}]}]}]}], "]"}], ")"}], "/.", 
      "PaVeEvalRules"}], "/.", "PVBasicRules"}], "/.", "PVExplicitRules"}], "//", 
   RowBox[{
    RowBox[{"Collect", "[", 
     RowBox[{"#", ",", 
      RowBox[{"{", 
       RowBox[{"_BubbleFunc", ",", "_TriangleFunc"}], "}"}], ",", 
      "Simplify"}], "]"}], "&"}]}]}], "\[IndentingNewLine]", 
 RowBox[{
  RowBox[{"ampsfse", "[", "3", "]"}], "=", 
  RowBox[{
   RowBox[{"Normal", "[", 
    RowBox[{"Series", "[", 
     RowBox[{
      RowBox[{
       RowBox[{
        RowBox[{
         RowBox[{"ampsfse", "[", "2", "]"}], 
         RowBox[{"MSBarFac", "[", "Epsilon", "]"}]}], "/.", "LoopFuncRules"}],
        "/.", 
       RowBox[{"c\[CapitalGamma]Rule", "[", "Epsilon", "]"}]}], ",", 
      RowBox[{"{", 
       RowBox[{"Epsilon", ",", "0", ",", "0"}], "}"}]}], "]"}], "]"}], "//", 
   RowBox[{
    RowBox[{"Collect", "[", 
     RowBox[{"#", ",", 
      RowBox[{"{", "Epsilon", "}"}], ",", "Simplify"}], "]"}], 
    "&"}]}]}], "\[IndentingNewLine]", 
 RowBox[{
  RowBox[{
   RowBox[{"ampsfse", "[", "3", "]"}], "-", 
   RowBox[{"(", 
    RowBox[{
     RowBox[{
      RowBox[{"ampsfse", "[", "1", "]"}], "//", 
      "FeynAmpDenominatorExplicit"}], "//", 
     RowBox[{
      RowBox[{"PaXEvaluate", "[", 
       RowBox[{"#", ",", 
        RowBox[{"PaXImplicitPrefactor", "\[Rule]", 
         SuperscriptBox[
          RowBox[{"(", 
           FractionBox[
            RowBox[{"Exp", "[", 
             RowBox[{"-", "EulerGamma"}], "]"}], "\[Pi]"], ")"}], 
          RowBox[{
           RowBox[{"(", 
            RowBox[{"D", "-", "4"}], ")"}], "/", "2"}]]}]}], "]"}], "&"}]}], 
    ")"}]}], "//", 
  RowBox[{
   RowBox[{"Collect", "[", 
    RowBox[{"#", ",", 
     RowBox[{"{", "Epsilon", "}"}], ",", "Simplify"}], "]"}], 
   "&"}]}]}], "Input",
