Cell[CellGroupData[{

Cell[BoxData[{
 RowBox[{
  RowBox[{"MyBoxNAbACL", "=", 
   RowBox[{
    RowBox[{
     FractionBox[
      SubscriptBox["c", "\[CapitalGamma]"], 
      SuperscriptBox["\[Epsilon]", "2"]], 
     FractionBox["2", "t"], 
     SuperscriptBox[
      RowBox[{"(", 
       RowBox[{"-", 
        FractionBox[
         SuperscriptBox["\[Mu]", "2"], "t"]}], ")"}], "\[Epsilon]"], 
     RowBox[{"(", 
      RowBox[{
       RowBox[{"z", " ", 
        RowBox[{"Hypergeometric2F1", "[", 
         RowBox[{"1", ",", "1", ",", 
          RowBox[{"1", "-", "\[Epsilon]"}], ",", 
          RowBox[{"1", "-", "z"}]}], "]"}]}], "-", 
       RowBox[{"2", " ", 
        RowBox[{"(", 
         RowBox[{"1", "-", "z"}], ")"}], " ", 
        RowBox[{"Hypergeometric2F1", "[", 
         RowBox[{"1", ",", "1", ",", 
          RowBox[{"1", "-", "\[Epsilon]"}], ",", "z"}], "]"}]}], "-", "1"}], 
      ")"}]}], "-", 
    RowBox[{
     FractionBox[
      SubscriptBox["c", "\[CapitalGamma]"], 
      SuperscriptBox["\[Epsilon]", "2"]], 
     FractionBox["1", "t"], 
     SuperscriptBox[
      RowBox[{"(", 
       RowBox[{"-", 
        FractionBox[
         SuperscriptBox["\[Mu]", "2"], 
         SuperscriptBox["Q", "2"]]}], ")"}], "\[Epsilon]"], 
     FractionBox[
      RowBox[{"2", "-", 
       RowBox[{"3", "\[Epsilon]"}]}], 
      RowBox[{"1", "-", 
       RowBox[{"2", " ", "\[Epsilon]"}]}]]}]}]}], " ", 
  ";"}], "\[IndentingNewLine]", 
 RowBox[{"Simplify", "[", 
  RowBox[{
   RowBox[{
    RowBox[{
     RowBox[{"Simplify", "[", 
      RowBox[{
       RowBox[{
        RowBox[{
         RowBox[{"MyBoxNAbACL", "-", "MyBoxNAbA"}], "/.", "LoopFuncRules"}], "/.", 
        RowBox[{"{", 
         RowBox[{
          RowBox[{"s", "\[Rule]", 
           RowBox[{
            SuperscriptBox["Q", "2"], "z"}]}], ",", 
          RowBox[{"u", "\[Rule]", 
           RowBox[{
            SuperscriptBox["Q", "2"], 
            RowBox[{"(", 
             RowBox[{"1", "-", "z"}], ")"}]}]}]}], "}"}]}], "/.", 
       RowBox[{"{", 
        RowBox[{
         RowBox[{
          RowBox[{
           SuperscriptBox["Q", "2"], "+", "t"}], "\[Rule]", 
          SuperscriptBox["Q", "2"]}], ",", 
         RowBox[{
          RowBox[{
           RowBox[{"a_", " ", 
            SuperscriptBox["Q", "2"]}], "-", "t"}], "\[Rule]", 
          RowBox[{"a", " ", 
           SuperscriptBox["Q", "2"]}]}], ",", 
         RowBox[{
          RowBox[{
           RowBox[{"a_", " ", 
            SuperscriptBox["Q", "2"]}], "+", "t"}], "\[Rule]", 
          RowBox[{"a", " ", 
           SuperscriptBox["Q", "2"]}]}]}], "}"}]}], "]"}], "/.", 
     RowBox[{"{", 
      RowBox[{
       RowBox[{
        RowBox[{"1", "+", 
         FractionBox["t", 
          RowBox[{
           SuperscriptBox["Q", "2"], " ", 
           RowBox[{"(", 
            RowBox[{
             RowBox[{"-", "1"}], "+", "z"}], ")"}]}]]}], "\[Rule]", "1"}], 
       ",", 
       RowBox[{
        RowBox[{"1", "-", 
         FractionBox["t", 
          RowBox[{
           SuperscriptBox["Q", "2"], " ", "z"}]]}], "\[Rule]", "1"}], ",", 
       RowBox[{
        RowBox[{"1", "+", 
         FractionBox[
          RowBox[{"t", " ", 
           RowBox[{"(", 
            RowBox[{
             RowBox[{"-", "1"}], "+", "z"}], ")"}]}], 
          RowBox[{
           SuperscriptBox["Q", "2"], " ", "z"}]]}], "\[Rule]", "1"}], ",", 
       RowBox[{
        RowBox[{"1", "+", 
         FractionBox[
          RowBox[{"t", " ", "z"}], 
          RowBox[{
           SuperscriptBox["Q", "2"], " ", 
           RowBox[{"(", 
            RowBox[{
             RowBox[{"-", "1"}], "+", "z"}], ")"}]}]]}], "\[Rule]", "1"}]}], 
      "}"}]}], "/.", 
    RowBox[{"{", 
     RowBox[{
      RowBox[{
       RowBox[{"Hypergeometric2F1", "[", 
        RowBox[{
         RowBox[{"c", "-", "a"}], ",", 
         RowBox[{"c", "-", "b"}], ",", "c", ",", "z_"}], "]"}], "\[Rule]", 
       "\[IndentingNewLine]", 
       RowBox[{
        RowBox[{
         RowBox[{"(", 
          RowBox[{"1", "-", "z"}], ")"}], "^", 
         RowBox[{"(", 
          RowBox[{
           RowBox[{"-", "c"}], "+", "a", "+", "b"}], ")"}]}], 
        RowBox[{"Hypergeometric2F1", "[", 
         RowBox[{"a", ",", "b", ",", "c", ",", "z"}], "]"}]}]}], "/.", 
      RowBox[{"{", 
       RowBox[{
        RowBox[{"a", "\[Rule]", 
         RowBox[{"-", "\[Epsilon]"}]}], ",", 
        RowBox[{"b", "\[Rule]", 
         RowBox[{"-", "\[Epsilon]"}]}], ",", 
        RowBox[{"c", "\[Rule]", 
         RowBox[{"1", "-", "\[Epsilon]"}]}]}], "}"}]}], "}"}]}], ",", 
   RowBox[{"Assumptions", "\[Rule]", 
    RowBox[{"{", 
     RowBox[{"0", "<", "z", "<", "1"}], "}"}]}]}], "]"}]}], "Input",
