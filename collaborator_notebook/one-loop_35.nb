Cell[BoxData[
 RowBox[{"(*", 
  RowBox[{
   RowBox[{"HypExpand", "[", 
    RowBox[{"f_", ",", "\[Epsilon]_", ",", "n_"}], "]"}], ":=", 
   RowBox[{
    RowBox[{"f", "/.", 
     RowBox[{"(", 
      RowBox[{
       RowBox[{
        RowBox[{"#", "\[Rule]", 
         RowBox[{"FullSimplify", "[", 
          RowBox[{"HypExp", "[", 
           RowBox[{"#", ",", "\[Epsilon]", ",", "n"}], "]"}], "]"}]}], "&"}], 
       "/@", "\[IndentingNewLine]", 
       RowBox[{"DeleteDuplicates", "[", 
        RowBox[{"Cases", "[", 
         RowBox[{"f", ",", 
          RowBox[{"Hypergeometric2F1", "[", 
           RowBox[{"a_", ",", "b_", ",", "c_", ",", "z_"}], "]"}], ",", 
          "Infinity"}], "]"}], "]"}]}], ")"}]}], "/.", "\[IndentingNewLine]", 
    
    RowBox[{"(", 
     RowBox[{
      RowBox[{
       RowBox[{"#", "\[Rule]", 
        RowBox[{"FullSimplify", "[", 
         RowBox[{"HypExp", "[", 
          RowBox[{"#", ",", "\[Epsilon]", ",", "n"}], "]"}], "]"}]}], "&"}], "/@", 
      RowBox[{"DeleteDuplicates", "[", 
       RowBox[{"Cases", "[", 
        RowBox[{"f", ",", "\[IndentingNewLine]", 
         RowBox[{"HypergeometricPFQ", "[", 
          RowBox[{"a__", ",", "b__", ",", "z_"}], "]"}], ",", "Infinity"}], 
        "]"}], "]"}]}], ")"}]}]}], "*)"}]], "Input",
 CellChangeTimes->{{3.93406907747314*^9, 3.934069080763986*^9}},
