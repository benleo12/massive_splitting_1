 RowBox[{
  RowBox[{"ampssse", "[", "0", "]"}], "=", 
  RowBox[{
   RowBox[{"FCFAConvert", "[", 
    RowBox[{
     RowBox[{"CreateFeynAmp", "[", 
      RowBox[{"diagssse", ",", 
       RowBox[{"GaugeRules", "\[Rule]", 
        RowBox[{"{", "}"}]}]}], "]"}], ",", 
     RowBox[{"IncomingMomenta", "\[Rule]", 
