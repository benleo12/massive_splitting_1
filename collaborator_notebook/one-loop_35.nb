Cell[BoxData[{
 RowBox[{
  RowBox[{"Paint", "[", 
   RowBox[{
    RowBox[{"DiagramExtract", "[", 
     RowBox[{"diagsl2", ",", 
      RowBox[{"{", 
       RowBox[{"9", ",", "11"}], "}"}]}], "]"}], ",", 
    RowBox[{"ColumnsXRows", "\[Rule]", 
     RowBox[{"{", 
      RowBox[{"5", ",", "1"}], "}"}]}], ",", 
    RowBox[{"Numbering", "\[Rule]", "Simple"}], ",", 
