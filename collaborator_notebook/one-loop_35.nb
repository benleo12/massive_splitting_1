Cell["Filter function to determine missing replacement rules", "Text",
 CellChangeTimes->{{3.933876921611013*^9, 
  3.9338769474189653`*^9}},ExpressionUUID->"de020e06-8871-4c48-8e46-\
f460f40537bb"],

Cell[BoxData[
 RowBox[{
  RowBox[{"PVCaseFilter", "[", "f_", "]"}], ":=", 
  RowBox[{"StandardForm", "[", 
   RowBox[{"Join", "[", "\[IndentingNewLine]", 
    RowBox[{
     RowBox[{
      RowBox[{
       RowBox[{"(", 
        RowBox[{"#", "\[Rule]", 
         RowBox[{"(", 
          RowBox[{"#", "/.", 
           RowBox[{"{", 
            RowBox[{"B0", "\[Rule]", "PVB"}], "}"}]}], ")"}]}], ")"}], "&"}], 
      "/@", 
      RowBox[{"DeleteDuplicates", "[", 
       RowBox[{"Cases", "[", 
        RowBox[{"f", ",", 
         RowBox[{"B0", "[", "__", "]"}], ",", "Infinity"}], "]"}], "]"}]}], 
     ",", "\[IndentingNewLine]", 
     RowBox[{
      RowBox[{
       RowBox[{"(", 
        RowBox[{"#", "\[Rule]", 
         RowBox[{"(", 
          RowBox[{"#", "/.", 
           RowBox[{"{", 
            RowBox[{"C0", "\[Rule]", "PVC"}], "}"}]}], ")"}]}], ")"}], "&"}], 
      "/@", 
      RowBox[{"DeleteDuplicates", "[", 
       RowBox[{"Cases", "[", 
        RowBox[{"f", ",", 
         RowBox[{"C0", "[", "__", "]"}], ",", "Infinity"}], "]"}], "]"}]}], 
     ",", "\[IndentingNewLine]", 
     RowBox[{
      RowBox[{
       RowBox[{"(", 
        RowBox[{"#", "\[Rule]", 
         RowBox[{"(", 
          RowBox[{"#", "/.", 
           RowBox[{"{", 
            RowBox[{"D0", "\[Rule]", "PVD"}], "}"}]}], ")"}]}], ")"}], "&"}], 
      "/@", 
      RowBox[{"DeleteDuplicates", "[", 
       RowBox[{"Cases", "[", 
        RowBox[{"f", ",", 
         RowBox[{"D0", "[", "__", "]"}], ",", "Infinity"}], "]"}], "]"}]}], 
     ",", "\[IndentingNewLine]", 
     RowBox[{
      RowBox[{
       RowBox[{"(", 
        RowBox[{
         RowBox[{"#", "\[Rule]", 
          RowBox[{"(", 
           RowBox[{"#", "/.", 
            RowBox[{"{", 
             RowBox[{"B0", "\[Rule]", "PVB"}], "}"}]}], ")"}]}], "/.", 
         RowBox[{"{", 
          RowBox[{
           RowBox[{
            RowBox[{"(", 
             RowBox[{"PaVeAutoOrder", "\[Rule]", "True"}], ")"}], "\[Rule]", 
            "_"}], ",", 
           RowBox[{
            RowBox[{"(", 
             RowBox[{"PaVeAutoReduce", "\[Rule]", "True"}], ")"}], "\[Rule]", 
            "_"}]}], "}"}]}], ")"}], "&"}], "/@", 
      RowBox[{"DeleteDuplicates", "[", 
       RowBox[{"Cases", "[", 
        RowBox[{"f", ",", 
         RowBox[{"PaVe", "[", "__", "]"}], ",", "Infinity"}], "]"}], 
       "]"}]}]}], "]"}], "]"}]}]], "Input",
 CellLabel->"In[24]:=",ExpressionUUID->"d8424de1-71a3-45f5-a38d-e8b93334ce2b"]
}, Open  ]],

