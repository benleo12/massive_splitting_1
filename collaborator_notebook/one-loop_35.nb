Cell[CellGroupData[{

Cell[BoxData[{
 RowBox[{
  RowBox[{"diagsfse", "=", 
   RowBox[{"InsertFields", "[", 
    RowBox[{
     RowBox[{"CreateTopologies", "[", 
      RowBox[{"1", ",", 
       RowBox[{"1", "\[Rule]", "1"}], ",", 
       RowBox[{"ExcludeTopologies", "\[Rule]", 
        RowBox[{"{", "Tadpoles", "}"}]}]}], "]"}], ",", 
     RowBox[{
      RowBox[{"{", 
       RowBox[{"F", "[", 
        RowBox[{"3", ",", 
         RowBox[{"{", 
          RowBox[{"1", ",", "i1"}], "}"}]}], "]"}], "}"}], "\[Rule]", 
      RowBox[{"{", 
       RowBox[{"F", "[", 
        RowBox[{"3", ",", 
         RowBox[{"{", 
          RowBox[{"1", ",", "i2"}], "}"}]}], "]"}], "}"}]}], ",", 
     RowBox[{"InsertionLevel", "\[Rule]", 
      RowBox[{"{", "Classes", "}"}]}], ",", 
     RowBox[{"Model", "\[Rule]", 
      RowBox[{"FileNameJoin", "[", 
       RowBox[{"{", 
        RowBox[{"\"\<SQCDBGF\>\"", ",", "\"\<SQCDBGF\>\""}], "}"}], "]"}]}], 
     ",", 
     RowBox[{"GenericModel", "\[Rule]", 
      RowBox[{"FileNameJoin", "[", 
       RowBox[{"{", 
        RowBox[{"\"\<SQCDBGF\>\"", ",", "\"\<SQCDBGF\>\""}], "}"}], "]"}]}], 
     ",", 
     RowBox[{"ExcludeParticles", "\[Rule]", 
      RowBox[{"{", 
       RowBox[{
        RowBox[{"S", "[", "1", "]"}], ",", 
        RowBox[{"S", "[", "_", "]"}]}], "}"}]}]}], "]"}]}], 
  ";"}], "\[IndentingNewLine]", 
 RowBox[{
  RowBox[{"Paint", "[", 
   RowBox[{"diagsfse", ",", 
    RowBox[{"ColumnsXRows", "\[Rule]", 
     RowBox[{"{", 
      RowBox[{"5", ",", "1"}], "}"}]}], ",", 
    RowBox[{"Numbering", "\[Rule]", "Simple"}], ",", 
    RowBox[{"SheetHeader", "\[Rule]", "None"}], ",", 
