Cell[BoxData[{
 RowBox[{
  RowBox[{"Paint", "[", 
   RowBox[{
    RowBox[{"DiagramExtract", "[", 
     RowBox[{"diags2", ",", 
      RowBox[{"{", 
       RowBox[{"13", ",", "15"}], "}"}]}], "]"}], ",", 
    RowBox[{"ColumnsXRows", "\[Rule]", 
     RowBox[{"{", 
