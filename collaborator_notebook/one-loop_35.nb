Cell["Vacuum polarization (Feynman gauge)", "Subsection",
 CellChangeTimes->{{3.9328154770433493`*^9, 3.932815491595804*^9}, {
  3.932822646625606*^9, 3.932822652465529*^9}, {3.933196244897315*^9, 
  3.933196248432632*^9}, {3.9336095128603697`*^9, 3.933609523518165*^9}, {
  3.9339835961109257`*^9, 3.9339835969522*^9}, {3.9339836599207993`*^9, 
  3.933983668271394*^9}},ExpressionUUID->"788ae680-54cd-4f6f-b998-\
c34c9b5eadff"],

Cell[CellGroupData[{

Cell[BoxData[{
 RowBox[{
  RowBox[{"diagsgse", "=", 
   RowBox[{"InsertFields", "[", 
    RowBox[{
     RowBox[{"CreateTopologies", "[", 
      RowBox[{"1", ",", 
       RowBox[{"1", "\[Rule]", "1"}], ",", 
       RowBox[{"ExcludeTopologies", "\[Rule]", 
        RowBox[{"{", "Tadpoles", "}"}]}]}], "]"}], ",", 
     RowBox[{
      RowBox[{"{", 
       RowBox[{"V", "[", 
        RowBox[{"50", ",", 
         RowBox[{"{", "a1", "}"}]}], "]"}], "}"}], "\[Rule]", 
      RowBox[{"{", 
       RowBox[{"V", "[", 
        RowBox[{"50", ",", 
         RowBox[{"{", "a2", "}"}]}], "]"}], "}"}]}], ",", 
     RowBox[{"InsertionLevel", "\[Rule]", 
      RowBox[{"{", "Classes", "}"}]}], ",", 
     RowBox[{"Model", "\[Rule]", 
      RowBox[{"FileNameJoin", "[", 
       RowBox[{"{", 
        RowBox[{"\"\<SQCDBGF\>\"", ",", "\"\<SQCDBGF\>\""}], "}"}], "]"}]}], 
     ",", 
     RowBox[{"GenericModel", "\[Rule]", 
      RowBox[{"FileNameJoin", "[", 
       RowBox[{"{", 
        RowBox[{"\"\<SQCDBGF\>\"", ",", "\"\<SQCDBGF\>\""}], "}"}], "]"}]}], 
     ",", 
     RowBox[{"ExcludeParticles", "\[Rule]", 
      RowBox[{"{", 
       RowBox[{
        RowBox[{"S", "[", "_", "]"}], ",", 
        RowBox[{"F", "[", "_", "]"}]}], "}"}]}]}], "]"}]}], 
  ";"}], "\[IndentingNewLine]", 
 RowBox[{
  RowBox[{"Paint", "[", 
   RowBox[{"diagsgse", ",", 
    RowBox[{"ColumnsXRows", "\[Rule]", 
     RowBox[{"{", 
      RowBox[{"5", ",", "1"}], "}"}]}], ",", 
    RowBox[{"Numbering", "\[Rule]", "Simple"}], ",", 
    RowBox[{"SheetHeader", "\[Rule]", "None"}], ",", 
    RowBox[{"ImageSize", "\[Rule]", 
     RowBox[{"{", 
      RowBox[{"1024", ",", "256"}], "}"}]}]}], "]"}], 
  ";"}], "\[IndentingNewLine]", 
 RowBox[{
  RowBox[{"ampsgse", "[", "0", "]"}], "=", 
  RowBox[{
   RowBox[{"FCFAConvert", "[", 
    RowBox[{
     RowBox[{"CreateFeynAmp", "[", "diagsgse", "]"}], ",", 
     RowBox[{"IncomingMomenta", "\[Rule]", 
      RowBox[{"{", "p", "}"}]}], ",", 
     RowBox[{"OutgoingMomenta", "\[Rule]", 
      RowBox[{"{", "p", "}"}]}], ",", 
     RowBox[{"ChangeDimension", "\[Rule]", "D"}], ",", 
     RowBox[{"List", "\[Rule]", "False"}], ",", 
     RowBox[{"LoopMomenta", "\[Rule]", 
      RowBox[{"{", "l", "}"}]}], ",", 
     RowBox[{"SMP", "\[Rule]", "True"}], ",", 
     RowBox[{"Contract", "\[Rule]", "True"}], ",", 
     RowBox[{"DropSumOver", "\[Rule]", "True"}], ",", 
     RowBox[{"FinalSubstitutions", "\[Rule]", 
      RowBox[{"{", 
       RowBox[{
        RowBox[{"MSf", "[", 
         RowBox[{"_", ",", "_", ",", "_"}], "]"}], "\[Rule]", "0"}], 
       "}"}]}]}], "]"}], "//", "Simplify"}]}], "\[IndentingNewLine]", 
 RowBox[{
  RowBox[{
   RowBox[{"ampsgse", "[", "1", "]"}], "=", 
   RowBox[{"TID", "[", 
    RowBox[{
     RowBox[{"FCE", "[", 
      RowBox[{"SUNSimplify", "[", 
       RowBox[{"ampsgse", "[", "0", "]"}], "]"}], "]"}], ",", "l", ",", 
     RowBox[{"UsePaVeBasis", "\[Rule]", "True"}], ",", 
     RowBox[{"ToPaVe", "\[Rule]", "True"}]}], "]"}]}], ";"}], "\n", 
 RowBox[{
  RowBox[{"ampsgse", "[", "2", "]"}], "=", 
  RowBox[{
   RowBox[{
    RowBox[{
     RowBox[{
      RowBox[{"(", 
       RowBox[{
        RowBox[{"FCReplaceD", "[", 
         RowBox[{
          RowBox[{"ampsgse", "[", "1", "]"}], ",", 
          RowBox[{"D", "\[Rule]", 
           RowBox[{"4", "-", 
            RowBox[{"2", "Epsilon"}]}]}]}], "]"}], "//", 
        "FeynAmpDenominatorExplicit"}], ")"}], "/.", "PaVeEvalRules"}], "/.", 
     "PVBasicRules"}], "/.", "PVExplicitRules"}], "//", "\[IndentingNewLine]", 
   RowBox[{
    RowBox[{"Collect2", "[", 
     RowBox[{"#", ",", 
      RowBox[{"{", 
       RowBox[{"_BubbleFunc", ",", "_TriangleFunc"}], "}"}], ",", 
      "Simplify"}], "]"}], "&"}]}]}], "\[IndentingNewLine]", 
 RowBox[{
  RowBox[{"ampsgse", "[", "3", "]"}], "=", 
  RowBox[{"Normal", "[", 
   RowBox[{"Series", "[", 
    RowBox[{
     RowBox[{
      RowBox[{
       RowBox[{
        RowBox[{"ampsgse", "[", "2", "]"}], 
        RowBox[{"MSBarFac", "[", "Epsilon", "]"}]}], "/.", "LoopFuncRules"}], 
      "/.", 
      RowBox[{"c\[CapitalGamma]Rule", "[", "Epsilon", "]"}]}], ",", 
     RowBox[{"{", 
      RowBox[{"Epsilon", ",", "0", ",", "0"}], "}"}]}], "]"}], 
   "]"}]}], "\[IndentingNewLine]", 
 RowBox[{
  RowBox[{
   RowBox[{"ampsgse", "[", "3", "]"}], "-", 
   RowBox[{"(", 
    RowBox[{
     RowBox[{
      RowBox[{"ampsgse", "[", "1", "]"}], "//", 
      "FeynAmpDenominatorExplicit"}], "//", 
     RowBox[{
      RowBox[{"PaXEvaluate", "[", 
       RowBox[{"#", ",", 
        RowBox[{"PaXImplicitPrefactor", "\[Rule]", 
         SuperscriptBox[
          RowBox[{"(", 
           FractionBox[
            RowBox[{"Exp", "[", 
             RowBox[{"-", "EulerGamma"}], "]"}], "\[Pi]"], ")"}], 
          RowBox[{
           RowBox[{"(", 
            RowBox[{"D", "-", "4"}], ")"}], "/", "2"}]]}]}], "]"}], "&"}]}], 
    ")"}]}], "//", 
  RowBox[{
   RowBox[{"Collect", "[", 
    RowBox[{"#", ",", 
     RowBox[{"{", "Epsilon", "}"}], ",", "Simplify"}], "]"}], 
   "&"}]}]}], "Input",
 CellChangeTimes->{
