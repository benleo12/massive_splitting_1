Cell[BoxData[
 RowBox[{
  RowBox[{"I4", "[", 
   RowBox[{"s_", ",", "t_", ",", "K32_"}], "]"}], ":=", 
  RowBox[{
   FractionBox[
    RowBox[{"2", 
     SubscriptBox["c", "\[CapitalGamma]"]}], 
    SuperscriptBox["Epsilon", "2"]], 
   RowBox[{"(", 
    RowBox[{
     RowBox[{
      SuperscriptBox[
       RowBox[{"(", 
        FractionBox[
         RowBox[{"t", "-", "K32"}], 
         RowBox[{"s", " ", "t"}]], ")"}], "Epsilon"], 
      RowBox[{"Hypergeometric2F1", "[", 
       RowBox[{
        RowBox[{"-", "\[Epsilon]"}], ",", 
        RowBox[{"-", "\[Epsilon]"}], ",", 
        RowBox[{"1", "-", "\[Epsilon]"}], ",", 
        RowBox[{"1", "+", 
         FractionBox["s", 
          RowBox[{"t", "-", "K32"}]]}]}], "]"}]}], "\[IndentingNewLine]", "+", 
     RowBox[{
      SuperscriptBox[
       RowBox[{"(", 
        FractionBox[
         RowBox[{"s", "-", "K32"}], 
         RowBox[{"s", " ", "t"}]], ")"}], "Epsilon"], 
      RowBox[{"Hypergeometric2F1", "[", 
       RowBox[{
        RowBox[{"-", "\[Epsilon]"}], ",", 
        RowBox[{"-", "\[Epsilon]"}], ",", 
        RowBox[{"1", "-", "\[Epsilon]"}], ",", 
        RowBox[{"1", "+", 
         FractionBox["t", 
          RowBox[{"s", "-", "K32"}]]}]}], "]"}]}], "\[IndentingNewLine]", "-", 
     RowBox[{
      SuperscriptBox[
       RowBox[{"(", 
        FractionBox[
         RowBox[{
          RowBox[{"(", 
           RowBox[{"s", "-", "K32"}], ")"}], 
          RowBox[{"(", 
           RowBox[{"t", "-", "K32"}], ")"}]}], 
         RowBox[{
          RowBox[{"-", "s"}], " ", "t", " ", "K32"}]], ")"}], "Epsilon"], 
      RowBox[{"Hypergeometric2F1", "[", 
       RowBox[{
        RowBox[{"-", "\[Epsilon]"}], ",", 
        RowBox[{"-", "\[Epsilon]"}], ",", 
        RowBox[{"1", "-", "\[Epsilon]"}], ",", 
        RowBox[{"1", "-", 
         FractionBox[
          RowBox[{"s", " ", "t"}], 
          RowBox[{
           RowBox[{"(", 
            RowBox[{"s", "-", "K32"}], ")"}], 
           RowBox[{"(", 
            RowBox[{"t", "-", "K32"}], ")"}]}]]}]}], "]"}]}]}], 
    ")"}]}]}]], "Input",
 CellChangeTimes->{{3.933201298818631*^9, 3.933201554257107*^9}, {
