Cell[BoxData[
 RowBox[{
  RowBox[{"LoopFuncRules", "=", 
   RowBox[{"{", 
    RowBox[{
     RowBox[{
      RowBox[{"BubbleFunc", "[", 
       RowBox[{"s_", ",", "\[Mu]_", ",", "\[Epsilon]_"}], "]"}], "\[Rule]", 
      RowBox[{
       FractionBox[
        RowBox[{"I", " ", 
         SubscriptBox["c", "\[CapitalGamma]"]}], 
        RowBox[{"\[Epsilon]", 
         RowBox[{"(", 
          RowBox[{"1", "-", 
           RowBox[{"2", "\[Epsilon]"}]}], ")"}]}]], 
       SuperscriptBox[
        RowBox[{"(", 
         RowBox[{"-", 
          FractionBox[
           SuperscriptBox["\[Mu]", "2"], "s"]}], ")"}], "\[Epsilon]"]}]}], 
     ",", "\[IndentingNewLine]", 
     RowBox[{
      RowBox[{"TriangleFunc", "[", 
       RowBox[{"s_", ",", "\[Mu]_", ",", "\[Epsilon]_"}], "]"}], "\[Rule]", 
      RowBox[{
       FractionBox[
        RowBox[{"I", " ", 
         SubscriptBox["c", "\[CapitalGamma]"]}], 
        SuperscriptBox["\[Epsilon]", "2"]], 
       FractionBox["1", "s"], 
       SuperscriptBox[
        RowBox[{"(", 
         RowBox[{"-", 
          FractionBox[
           SuperscriptBox["\[Mu]", "2"], "s"]}], ")"}], "\[Epsilon]"]}]}], 
     ",", "\[IndentingNewLine]", 
     RowBox[{
      RowBox[{"Triangle2Func", "[", 
       RowBox[{"s_", ",", "\[Mu]_", ",", "\[Epsilon]_"}], "]"}], "\[Rule]", 
      RowBox[{
       RowBox[{"-", 
        FractionBox[
         RowBox[{"I", " ", 
          SubscriptBox["c", "\[CapitalGamma]"]}], "\[Epsilon]"]}], 
       FractionBox["1", "s"], 
       SuperscriptBox[
        RowBox[{"(", 
         RowBox[{"-", 
          FractionBox[
           SuperscriptBox["\[Mu]", "2"], "s"]}], ")"}], "\[Epsilon]"]}]}], 
     ",", "\[IndentingNewLine]", 
     RowBox[{
      RowBox[{"TriangleFunc", "[", 
       RowBox[{"s_", ",", "t_", ",", "\[Mu]_", ",", "\[Epsilon]_"}], "]"}], 
      "\[Rule]", 
      RowBox[{
       FractionBox[
        RowBox[{"I", " ", 
         SubscriptBox["c", "\[CapitalGamma]"]}], 
        SuperscriptBox["\[Epsilon]", "2"]], 
       FractionBox["1", 
        RowBox[{"s", "-", "t"}]], 
       RowBox[{"(", 
        RowBox[{
         SuperscriptBox[
          RowBox[{"(", 
           RowBox[{"-", 
            FractionBox[
             SuperscriptBox["\[Mu]", "2"], "s"]}], ")"}], "\[Epsilon]"], "-", 
         
         SuperscriptBox[
          RowBox[{"(", 
           RowBox[{"-", 
            FractionBox[
             SuperscriptBox["\[Mu]", "2"], "t"]}], ")"}], "\[Epsilon]"]}], 
        ")"}]}]}], ",", "\[IndentingNewLine]", 
     RowBox[{
      RowBox[{"BoxFunc", "[", 
       RowBox[{
       "s_", ",", "t_", ",", "u_", ",", "\[Mu]_", ",", "\[Epsilon]_"}], "]"}],
       "\[Rule]", 
      RowBox[{
       FractionBox[
        RowBox[{"2", " ", "I", " ", 
         SubscriptBox["c", "\[CapitalGamma]"]}], 
        SuperscriptBox["\[Epsilon]", "2"]], 
       FractionBox["1", 
        RowBox[{"s", " ", "t"}]], 
       RowBox[{"(", 
        RowBox[{
         RowBox[{
          SuperscriptBox[
           RowBox[{"(", 
            RowBox[{"-", 
             FractionBox[
              RowBox[{"t", "+", "u"}], 
              RowBox[{"s", " ", 
               RowBox[{"t", "/", 
                SuperscriptBox["\[Mu]", "2"]}]}]]}], ")"}], "\[Epsilon]"], 
          " ", 
          RowBox[{"Hypergeometric2F1", "[", 
           RowBox[{
            RowBox[{"-", "\[Epsilon]"}], ",", 
            RowBox[{"-", "\[Epsilon]"}], ",", 
            RowBox[{"1", "-", "\[Epsilon]"}], ",", 
            RowBox[{"1", "-", 
             FractionBox["t", 
              RowBox[{"t", "+", "u"}]]}]}], "]"}]}], "\[IndentingNewLine]", 
         "+", 
         RowBox[{
          SuperscriptBox[
           RowBox[{"(", 
            RowBox[{"-", 
             FractionBox[
              RowBox[{"s", "+", "u"}], 
              RowBox[{"s", " ", 
               RowBox[{"t", "/", 
                SuperscriptBox["\[Mu]", "2"]}]}]]}], ")"}], "\[Epsilon]"], 
          " ", 
          RowBox[{"Hypergeometric2F1", "[", 
           RowBox[{
            RowBox[{"-", "\[Epsilon]"}], ",", 
            RowBox[{"-", "\[Epsilon]"}], ",", 
            RowBox[{"1", "-", "\[Epsilon]"}], ",", 
            RowBox[{"1", "-", 
             FractionBox["s", 
              RowBox[{"s", "+", "u"}]]}]}], "]"}]}], "\[IndentingNewLine]", 
         "-", 
         RowBox[{
          SuperscriptBox[
           RowBox[{"(", 
            RowBox[{"-", 
             FractionBox[
              RowBox[{
               RowBox[{"(", 
                RowBox[{"s", "+", "u"}], ")"}], " ", 
               RowBox[{"(", 
                RowBox[{"t", "+", "u"}], ")"}]}], 
              RowBox[{
               RowBox[{"(", 
                RowBox[{"s", "+", "t", "+", "u"}], ")"}], "s", " ", 
               RowBox[{"t", "/", 
                SuperscriptBox["\[Mu]", "2"], " "}]}]]}], ")"}], 
           "\[Epsilon]"], " ", 
          RowBox[{"Hypergeometric2F1", "[", 
           RowBox[{
            RowBox[{"-", "\[Epsilon]"}], ",", 
            RowBox[{"-", "\[Epsilon]"}], ",", 
            RowBox[{"1", "-", "\[Epsilon]"}], ",", 
            RowBox[{"1", "-", 
             FractionBox[
              RowBox[{"s", " ", "t"}], 
              RowBox[{
               RowBox[{"(", 
                RowBox[{"s", "+", "u"}], ")"}], " ", 
               RowBox[{"(", 
                RowBox[{"t", "+", "u"}], ")"}]}]]}]}], "]"}]}]}], ")"}]}]}]}],
     "}"}]}], ";"}]], "Input",
 CellChangeTimes->{{3.9337239796092787`*^9, 3.933724029398497*^9}, {
   3.9337243415435047`*^9, 3.93372438402489*^9}, {3.933724529011705*^9, 
