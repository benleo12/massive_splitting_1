       RowBox[{"SUNTF", "[", 
        RowBox[{
         RowBox[{"{", 
          RowBox[{"SUNIndex", "[", "ca", "]"}], "}"}], ",", 
         RowBox[{"SUNFIndex", "[", "ci", "]"}], ",", 
         RowBox[{"SUNFIndex", "[", "cl", "]"}]}], "]"}]}], "+", 
