          RowBox[{"List", "\[Rule]", "False"}], ",", 
          RowBox[{"LoopMomenta", "\[Rule]", 
           RowBox[{"{", 
            RowBox[{
             RowBox[{"-", "l"}], "+", "k1", "+", "k3"}], "}"}]}], ",", 
          RowBox[{"SMP", "\[Rule]", "True"}], ",", 
          RowBox[{"Contract", "\[Rule]", "True"}], ",", 
          RowBox[{"DropSumOver", "\[Rule]", "True"}], ",", 
          RowBox[{"FinalSubstitutions", "\[Rule]", 
           RowBox[{"{", 
            RowBox[{
             RowBox[{"MQU", "[", "__", "]"}], "\[Rule]", "0"}], "}"}]}]}], 
         "]"}], "/.", 
        RowBox[{"{", 
         RowBox[{
          RowBox[{
           RowBox[{"SUNTF", "[", 
            RowBox[{
             RowBox[{"{", "a_", "}"}], ",", "i_", ",", "j_"}], "]"}], " ", 
           RowBox[{"SUNTF", "[", 
            RowBox[{
             RowBox[{"{", "a_", "}"}], ",", "m_", ",", "l_"}], "]"}], 
           RowBox[{"SUNTF", "[", 
            RowBox[{
             RowBox[{"{", "b_", "}"}], ",", "k_", ",", "m_"}], "]"}]}], 
          "\[Rule]", 
          RowBox[{
           RowBox[{"I", "/", "2"}], 
           RowBox[{"(*", 
            RowBox[{"antisymmetric", " ", "part", " ", "only"}], "*)"}], " ", 
           
           RowBox[{"SUNF", "[", 
            RowBox[{"b", ",", "a", ",", 
             RowBox[{"SUNIndex", "[", "Glu6", "]"}]}], "]"}], " ", 
           RowBox[{"SUNTF", "[", 
            RowBox[{
             RowBox[{"{", 
              RowBox[{"SUNIndex", "[", "Glu6", "]"}], "}"}], ",", "k", ",", 
             "l"}], "]"}], 
           RowBox[{"SUNTF", "[", 
            RowBox[{
             RowBox[{"{", "a", "}"}], ",", "i", ",", "j"}], "]"}]}]}], 
         "}"}]}], ")"}], "+", "\[IndentingNewLine]", 
      RowBox[{"(", 
