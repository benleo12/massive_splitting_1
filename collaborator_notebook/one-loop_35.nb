     RowBox[{"{", 
      RowBox[{"1024", ",", "256"}], "}"}]}]}], "]"}], 
  ";"}], "\[IndentingNewLine]", 
 RowBox[{
  RowBox[{"ampsal1113", "[", "0", "]"}], "=", 
  RowBox[{"Simplify", "[", 
   RowBox[{
    RowBox[{"ScalarProductExpand", "[", "\[IndentingNewLine]", 
     RowBox[{"{", 
      RowBox[{
       RowBox[{"(", 
        RowBox[{
         RowBox[{"FCFAConvert", "[", 
          RowBox[{
           RowBox[{"CreateFeynAmp", "[", 
            RowBox[{"DiagramExtract", "[", 
             RowBox[{"diagsl2", ",", 
              RowBox[{"{", "9", "}"}]}], "]"}], "]"}], ",", 
           RowBox[{"IncomingMomenta", "\[Rule]", 
            RowBox[{"{", "p", "}"}]}], ",", 
           RowBox[{"OutgoingMomenta", "\[Rule]", 
            RowBox[{"{", 
             RowBox[{"k1", ",", "k2", ",", "k3"}], "}"}]}], ",", 
           RowBox[{"UndoChiralSplittings", "\[Rule]", "True"}], ",", 
           RowBox[{"ChangeDimension", "\[Rule]", "D"}], ",", 
           RowBox[{"List", "\[Rule]", "False"}], ",", 
           RowBox[{"LoopMomenta", "\[Rule]", 
            RowBox[{"{", 
             RowBox[{
              RowBox[{"-", "l"}], "+", "k1", "+", "k3"}], "}"}]}], ",", 
           RowBox[{"SMP", "\[Rule]", "True"}], ",", 
           RowBox[{"Contract", "\[Rule]", "True"}], ",", 
           RowBox[{"DropSumOver", "\[Rule]", "True"}], ",", 
           RowBox[{"FinalSubstitutions", "\[Rule]", 
            RowBox[{"{", 
             RowBox[{
              RowBox[{"MQU", "[", "__", "]"}], "\[Rule]", "0"}], "}"}]}]}], 
          "]"}], "/.", 
         RowBox[{"{", 
          RowBox[{
           RowBox[{
            RowBox[{"SUNTF", "[", 
             RowBox[{
              RowBox[{"{", "a_", "}"}], ",", "k_", ",", "m_"}], "]"}], 
            RowBox[{"SUNTF", "[", 
             RowBox[{
              RowBox[{"{", "a_", "}"}], ",", "i_", ",", "j_"}], "]"}], " ", 
            RowBox[{"SUNTF", "[", 
             RowBox[{
              RowBox[{"{", "b_", "}"}], ",", "m_", ",", "l_"}], "]"}]}], 
           "\[Rule]", 
           RowBox[{
            RowBox[{"1", "/", "2"}], 
            RowBox[{"(*", 
