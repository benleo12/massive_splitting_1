     RowBox[{
      RowBox[{"C2Func", "[", "s_", "]"}], "\[Rule]", 
      RowBox[{"Triangle2Func", "[", 
       RowBox[{"s", ",", "ScaleMu", ",", "Epsilon"}], "]"}]}], ",", 
     "\[IndentingNewLine]", 
     RowBox[{
      RowBox[{"CFunc", "[", 
       RowBox[{"s_", ",", "t_"}], "]"}], "\[Rule]", 
      RowBox[{"TriangleFunc", "[", 
       RowBox[{"s", ",", "t", ",", "ScaleMu", ",", "Epsilon"}], "]"}]}], ",", 
     "\[IndentingNewLine]", 
     RowBox[{
      RowBox[{"DFunc", "[", 
       RowBox[{"s_", ",", "t_", ",", "q2_"}], "]"}], "\[Rule]", 
